# Copy this file to ".env" and adjust values.

# Server port (the host usually sets this automatically)
PORT=3000

# Secret used to sign admin login sessions. CHANGE THIS to a long random string.
JWT_SECRET=please-change-this-to-a-long-random-secret

# Default admin account created by the seed script
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# --- Database (Turso / libSQL) ---
# Leave BOTH of these empty for local development: the app will then use a
# local SQLite file inside this folder (database/store.db).
# In production (Render etc.) set them to your Turso database credentials:
#   TURSO_DATABASE_URL=libsql://your-db-name-yourorg.turso.io
#   TURSO_AUTH_TOKEN=your-long-token
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=
